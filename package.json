{
  "name": "movie-diary",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run seed:local && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "wrangler d1 migrations apply movie-diary-db",
    "db:seed": "wrangler d1 execute movie-diary-db --file=database/seed.sql",
    "db:local": "wrangler d1 migrations apply movie-diary-db --local",
    "db:seed:local": "wrangler d1 execute movie-diary-db --local --file=database/seed.sql",
    "deploy": "npm run build && wrangler pages deploy .next",
    "dev:cf": "wrangler pages dev .next --d1 DB=movie-diary-db",
    "type-check": "tsc --noEmit",
    "seed:local": "node scripts/seed-local.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@libsql/client": "^0.17.3",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.11.1",
    "lucide-react": "^0.454.0",
    "next": "15.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5",
    "wrangler": "^3.88.0"
  }
}
